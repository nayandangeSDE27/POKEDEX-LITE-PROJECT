# Auth.js (next-auth v5) — required for OAuth login
AUTH_SECRET=                        # generate: openssl rand -base64 32

# GitHub OAuth — register at github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth — register at console.cloud.google.com (optional alternative)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Supabase — for cloud-synced favorites (free tier at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL — used for OAuth callback URLs
NEXTAUTH_URL=http://localhost:3000
